        "Исх. номер заявки": "tender.purchase_number",
        "Полное наименование участника": "company_profile.company.full_name",
        "Юридический адрес": "company_profile.company.legal_address_full",
        "Предмет закупки": "tender.subject",
        "Срок действия предложения, дней": "tender.offer_validity_days",
        "Должность подписанта": "company_profile.signatory.position",
        "ФИО подписанта": "company_profile.signatory.name_short"
      }
    },
    "predlozhenie": {
      "template_name": "03_Предложение_о_цене_договора_шаблон.docx",
      "output_name": "03_Предложение_о_цене.docx",
