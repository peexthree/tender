        "ОГРН": "company_profile.company.ogrn",
        "Юридический адрес": "company_profile.company.legal_address_full",
        "Расчетный счет": "company_profile.bank.account",
        "Наименование банка": "company_profile.bank.name",
        "Корреспондентский счет": "company_profile.bank.correspondent_account",
        "БИК": "company_profile.bank.bik",
        "Контактное лицо": "company_profile.contact.responsible_name_full",
        "E-mail": "company_profile.contact.email",
        "Телефон": "company_profile.contact.phone",
        "Должность подписанта": "company_profile.signatory.position",
        "ФИО подписанта": "company_profile.signatory.name_short"
      }
    },
    "zayavka": {
      "template_name": "02_Заявка_на_участие_в_закупке_шаблон.docx",
      "output_name": "02_Заявка_на_участие.docx",
      "fields": {
